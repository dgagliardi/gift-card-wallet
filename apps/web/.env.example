DATABASE_PATH=./data/gift-card-wallet.db
UPLOADS_PATH=./data/uploads
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Google Sign-In (OAuth 2.0) — required for production VPS unless you use email fallback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to "true" to allow email/password alongside Google (or as fallback when Google env vars are unset)
ENABLE_EMAIL_PASSWORD=

# Optional: Google Cloud Vision API key (server-only) for receipt OCR when in-browser OCR fails.
# Enable the Vision API on a GCP project, create an API key restricted to Vision API.
# https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=
